---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Gradient background -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(239,153,127,0.12) 0%, transparent 60%), var(--bg);"></div>

  <!-- Animated orbs -->
  <div class="orb w-96 h-96 top-1/4 -left-32" data-parallax="1.5"
       style="background: radial-gradient(circle, rgba(239,153,127,0.15) 0%, transparent 70%);"></div>
  <div class="orb w-64 h-64 bottom-1/4 right-0" data-parallax="0.8"
       style="background: radial-gradient(circle, rgba(239,153,127,0.08) 0%, transparent 70%);"></div>
  <div class="orb w-48 h-48 top-1/3 right-1/4" data-parallax="1.2"
       style="background: radial-gradient(circle, rgba(147,112,219,0.06) 0%, transparent 70%);"></div>

  <!-- Grid lines -->
  <div class="absolute inset-0 opacity-[0.025]"
       style="background-image: linear-gradient(var(--text) 1px, transparent 1px), linear-gradient(90deg, var(--text) 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Content -->
  <div class="container relative z-10 pt-24 pb-16">
    <div class="max-w-3xl">

      <!-- Available badge -->
      <div class="reveal mb-8 inline-flex items-center gap-2 px-4 py-2 rounded-full glass">
        <span class="w-2 h-2 rounded-full bg-green-400" style="box-shadow: 0 0 8px rgba(74,222,128,0.6);"></span>
        <span class="text-xs font-medium" style="color: var(--text-2);">{tr.hero.available}</span>
      </div>

      <!-- Name -->
      <h1 class="reveal reveal-delay-1 text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight mb-4 gradient-text">
        {tr.hero.greeting}
      </h1>

      <!-- Role -->
      <p class="reveal reveal-delay-2 text-xl sm:text-2xl font-medium mb-6" style="color: var(--accent);">
        {tr.hero.role}
      </p>

      <!-- Tagline -->
      <p class="reveal reveal-delay-3 text-lg leading-relaxed mb-10 max-w-xl" style="color: var(--text-2);">
        {tr.hero.tagline.split('\n').map((line, i) => (
          <span>{line}{i === 0 && <br/>}</span>
        ))}
      </p>

      <!-- CTAs -->
      <div class="reveal reveal-delay-4 flex flex-wrap gap-4">
        <a href="#projects" class="btn-accent">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
          {tr.hero.cta}
        </a>
        <a href={lang === 'en' ? '/en/cv' : '/cv'} class="btn-ghost">
          {tr.hero.ctaCV}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="reveal reveal-delay-5 flex flex-wrap gap-8 mt-14 pt-8" style="border-top: 1px solid var(--border);">
        {[
          { value: '15+', label: lang === 'cs' ? 'let zkušeností' : 'years experience' },
          { value: '10+', label: lang === 'cs' ? 'studií & titulů' : 'shipped titles' },
          { value: '6', label: lang === 'cs' ? 'studií & míst' : 'studios & employers' },
        ].map(({ value, label }) => (
          <div>
            <div class="text-3xl font-bold accent">{value}</div>
            <div class="text-sm mt-1" style="color: var(--text-2);">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-40">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color: var(--text-2);">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
