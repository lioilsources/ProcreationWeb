---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const items = tr.projects.items;
---

<section id="projects" class="section" style="background: var(--bg2);">
  <div class="container">

    <div class="mb-16">
      <div class="reveal section-label">{tr.projects.title}</div>
      <h2 class="reveal reveal-delay-1 section-title">{tr.projects.subtitle}</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5">

      <!-- Orbitron - featured large card -->
      <div class="reveal md:col-span-2 glass group relative overflow-hidden" style="min-height: 280px;">
        <!-- Background image -->
        <div class="absolute inset-0 opacity-20 group-hover:opacity-30 transition-opacity duration-500"
             style="background: linear-gradient(135deg, rgba(239,153,127,0.3) 0%, rgba(147,112,219,0.2) 100%);"></div>

        <div class="relative z-10 p-8 md:p-10 flex flex-col md:flex-row gap-8 items-start">
          <!-- Left -->
          <div class="flex-1">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4 text-xs font-semibold uppercase tracking-wider"
                 style="background: var(--accent-glow); color: var(--accent); border: 1px solid var(--border-accent);">
              Steam Release
            </div>
            <h3 class="text-2xl md:text-3xl font-bold mb-3" style="color: var(--text);">{items.orbitron.name}</h3>
            <p class="text-base leading-relaxed mb-6" style="color: var(--text-2);">{items.orbitron.desc}</p>
            <div class="flex flex-wrap gap-2">
              {items.orbitron.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>

          <!-- Right - project image -->
          <div class="w-full md:w-64 rounded-2xl overflow-hidden flex-shrink-0" style="aspect-ratio: 3/4; max-height: 200px; background: var(--bg3);">
            <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(239,153,127,0.1), rgba(147,112,219,0.1));">
              <span class="text-4xl font-black opacity-20" style="color: var(--accent);">ORB</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Carrier Command -->
      <div class="reveal reveal-delay-1 glass group relative overflow-hidden p-7" style="min-height: 220px;">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full -translate-y-1/2 translate-x-1/2"
             style="background: radial-gradient(circle, rgba(96,165,250,0.08), transparent 70%);"></div>
        <div class="relative">
          <div class="w-10 h-10 rounded-xl mb-5 flex items-center justify-center text-sm font-bold"
               style="background: rgba(96,165,250,0.1); border: 1px solid rgba(96,165,250,0.2); color: #60a5fa;">CC</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--text);">{items.carrier.name}</h3>
          <p class="text-sm leading-relaxed mb-5" style="color: var(--text-2);">{items.carrier.desc}</p>
          <div class="flex flex-wrap gap-2">
            {items.carrier.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>

      <!-- RS Plan -->
      <div class="reveal reveal-delay-2 glass group relative overflow-hidden p-7" style="min-height: 220px;">
        <div class="absolute top-0 right-0 w-32 h-32 rounded-full -translate-y-1/2 translate-x-1/2"
             style="background: radial-gradient(circle, rgba(0,151,157,0.1), transparent 70%);"></div>
        <div class="relative flex flex-col h-full">
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-xl flex-shrink-0 overflow-hidden flex items-center justify-center text-sm font-bold"
                 style="background: rgba(0,151,157,0.1); border: 1px solid rgba(0,151,157,0.2); color: #00979d;">RS</div>
            <div class="flex-1">
              <h3 class="text-lg font-bold mb-2" style="color: var(--text);">{items.rsplan.name}</h3>
              <p class="text-sm leading-relaxed mb-4" style="color: var(--text-2);">{items.rsplan.desc}</p>
            </div>
          </div>
          <!-- Project image -->
          <div class="mt-4 rounded-xl overflow-hidden" style="height: 80px; background: var(--bg3);">
            <img src="/assets/rsplan095.png" alt="RS Plan 095"
                 class="w-full h-full object-cover object-top opacity-60 group-hover:opacity-80 transition-opacity duration-300" />
          </div>
          <div class="flex flex-wrap gap-2 mt-4">
            {items.rsplan.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>

      <!-- WebGL Games -->
      <div class="reveal reveal-delay-3 md:col-span-2 glass p-7">
        <div class="flex flex-col md:flex-row gap-6 md:items-center">
          <div class="flex-1">
            <h3 class="text-lg font-bold mb-2" style="color: var(--text);">{items.paco.name}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-2);">{items.paco.desc}</p>
          </div>
          <div class="flex flex-wrap gap-2 flex-shrink-0">
            {items.paco.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
